# Set to `false` to disable GLB loading (cubes only). Default in code is ON when unset.
# VITE_USE_UNIT_GLB=false

# Colyseus multiplayer (optional in local dev: Vite dev defaults to http://localhost:2567 when unset).
# Override if the server uses another host/port, or set for production builds (use wss/https when the game is served over HTTPS).
# VITE_COLYSEUS_URL=http://localhost:2567
