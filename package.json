{
  "name": "signal-wars",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "localhost": "node scripts/reset-localhost-dev.mjs",
    "dev:reset": "node scripts/reset-localhost-dev.mjs",
    "dev:lan": "vite --host",
    "assets:sync-cards": "node scripts/sync-card-manifest.mjs",
    "cards:pipeline": "node scripts/cards-pipeline.mjs",
    "build": "node scripts/verify-public-glbs.mjs && node scripts/sync-card-manifest.mjs && vite build",
    "preview": "vite preview",
    "multiplayer:dev": "tsx server/src/index.ts",
    "multiplayer:check": "tsc -p server/tsconfig.json",
    "test": "vitest run",
    "playwright:install-browsers": "playwright install chromium",
    "assets:sync-manifest": "node scripts/sync-unit-manifest.mjs",
    "assets:optimize-glb": "node scripts/optimize-glb.mjs",
    "assets:import-meshy": "node scripts/import-meshy-assets.mjs incoming",
    "assets:import-meshy:optimize": "node scripts/import-meshy-assets.mjs --optimize incoming",
    "assets:inspect-glbs": "node scripts/inspect-unit-glbs.mjs",
    "assets:fix-texture-webp": "node scripts/fix-ext-texture-webp.mjs"
  },
  "dependencies": {
    "@colyseus/schema": "^4.0.20",
    "@colyseus/sdk": "^0.17.42",
    "@supabase/supabase-js": "^2.105.1",
    "colyseus": "^0.17.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.3.0",
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "sharp": "^0.34.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^4.7.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
